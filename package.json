{
  "name": "@finografic/oxc-config",
  "version": "2.3.4",
  "description": "Shareable oxfmt formatter and oxlint linter configuration for the finografic ecosystem",
  "keywords": [
    "config",
    "finografic",
    "genx:type:config",
    "oxc-config",
    "oxfmt-config",
    "oxlint-config",
    "shared-config"
  ],
  "homepage": "https://github.com/finografic/oxc-config",
  "bugs": {
    "url": "https://github.com/finografic/oxc-config/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://github.com/finografic"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/oxc-config.git"
  },
  "files": [
    "dist",
    "internal/schemas",
    "docs/MIGRATION_GUIDE.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./oxfmt": "./dist/oxfmt.mjs",
    "./oxlint": "./dist/oxlint.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· CONFIGS_AND_SCHEMAS": "·······································",
    "schemas:update": "tsx ./scripts/update-schemas.ts",
    "oxlint:config:capture": "tsx ./scripts/print-oxlint-config.ts",
    "oxlint:config:capture:defaults": "tsx ./scripts/print-oxlint-config.ts --defaults",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt -c oxfmt.config.ts --check",
    "format": "oxfmt -c oxfmt.config.ts",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm format:check && pnpm lint:fix && pnpm typecheck && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/oxc-config --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:core": "pnpm update @finografic/core --latest",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:finografic:all": "pnpm update:core && update:md-lint",
    "update:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@finografic/core": "^0.12.1",
    "@finografic/md-lint": "^0.7.0",
    "@finografic/project-scripts": "^1.3.3",
    "@types/node": "^24.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "oxfmt": ">=0.41.0",
    "oxlint": ">=1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
